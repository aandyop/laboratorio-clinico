<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Valores de Referencia - Laboratorio</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <nav>
        <a href="/pacientes">Pacientes</a> | 
        <a href="/examenes">Exámenes</a> |
        <a href="/facturas">Facturación</a> |
        <a href="/medicos">Médicos</a> |
        <a href="/inventario">Inventario</a> |
        <a href="/valores"><strong>Valores Ref.</strong></a>
        <button onclick="logout()" style="float: right; background: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Cerrar Sesión</button>
    </nav>

    <h1>Configuración de Valores de Referencia</h1>

    <section class="container">
        <div class="card">
            <form id="valores-form">
                <input type="text" id="nombre_examen" placeholder="Nombre del Examen (ej: Glucosa)" required>
                <div style="margin: 10px 0;">
                    <input type="number" id="valor_minimo" step="0.01" placeholder="Mínimo" required>
                    <span> hasta </span>
                    <input type="number" id="valor_maximo" step="0.01" placeholder="Máximo" required>
                </div>
                <input type="text" id="unidad" placeholder="Unidad (ej: mg/dL)" required>
                <button type="submit" class="btn-guardar">Guardar Rango de Referencia</button>
            </form>
        </div>
    </section>

    <hr>

    <section>
        <h2>Diccionario de Referencias Médicas</h2>
        <table border="1" id="valores-table">
            <thead>
                <tr>
                    <th>Examen</th>
                    <th>Rango Normal</th>
                    <th>Unidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </section>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login';

        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('rol');
            window.location.href = '/login';
        }

        async function cargarValores() {
            try {
                const response = await fetch('/api/valores-referencia', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const valores = await response.json();
                const tbody = document.querySelector('#valores-table tbody');
                tbody.innerHTML = '';
                
                valores.forEach(v => {
                    tbody.innerHTML += `
                        <tr>
                            <td><strong>${v.nombre_examen}</strong></td>
                            <td>${v.valor_minimo} - ${v.valor_maximo}</td>
                            <td>${v.unidad}</td>
                            <td>
                                <button onclick="eliminarValor(${v.id})" style="background:#ff4d4d; color:white; border:none; cursor:pointer; padding:3px 8px;">Borrar</button>
                            </td>
                        </tr>`;
                });
            } catch (err) { 
                console.error("Error al cargar valores:", err); 
            }
        }

        document.getElementById('valores-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const vMin = parseFloat(document.getElementById('valor_minimo').value);
            const vMax = parseFloat(document.getElementById('valor_maximo').value);

            if (vMin >= vMax) {
                alert("Error lógico: El valor mínimo no puede ser mayor o igual al máximo.");
                return;
            }

            const datos = {
                nombre_examen: document.getElementById('nombre_examen').value,
                valor_minimo: vMin,
                valor_maximo: vMax,
                unidad: document.getElementById('unidad').value
            };

            const response = await fetch('/api/valores-referencia', {
                method: 'POST',
                headers: { 
                    'Authorization': `Bearer ${token}`, 
                    'Content-Type': 'application/json' 
                },
                body: JSON.stringify(datos)
            });

            if (response.ok) {
                document.getElementById('valores-form').reset();
                cargarValores();
            } else {
                alert("Error al guardar los valores de referencia");
            }
        });

        async function eliminarValor(id) {
            if (!confirm("¿Eliminar este valor de referencia? Esto afectará la interpretación de futuros exámenes.")) return;

            try {
                const response = await fetch(`/api/valores-referencia/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.ok) {
                    cargarValores();
                } else {
                    alert("No se pudo eliminar el valor.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        cargarValores();
    </script>
</body>
</html>