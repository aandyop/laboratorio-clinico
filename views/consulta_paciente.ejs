<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consultar Resultados - LabSys</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #e9ecef 0%, #dee2e6 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }
        .search-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            overflow: hidden;
            max-width: 450px;
            width: 100%;
            background: white;
        }
        .search-header {
            background-color: #0d6efd;
            color: white;
            padding: 30px;
            text-align: center;
        }
        .btn-search {
            background-color: #0d6efd;
            color: white;
            border-radius: 12px;
            padding: 14px;
            font-weight: bold;
            transition: all 0.3s;
            border: none;
        }
        .btn-search:hover {
            background-color: #0b5ed7;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
        }
        .info-banner {
            background-color: #f8f9fa;
            border-left: 4px solid #ffc107;
            padding: 15px;
            border-radius: 8px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <div class="card search-card animate__animated animate__fadeIn">
        <div class="search-header">
            <i class="fas fa-file-invoice fa-3x mb-3"></i>
            <h3 class="mb-0">Mis Resultados</h3>
            <p class="small opacity-75 mb-0">Ingrese sus datos para descargar</p>
        </div>
        
        <div class="card-body p-4">
            <div class="info-banner mb-4">
                <i class="fas fa-info-circle text-warning me-2"></i>
                Consulte su comprobante para obtener el número de orden asignado el día de su toma de muestra.
            </div>

            <form id="consultaForm">
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Número de Orden</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-hashtag text-muted"></i></span>
                        <input type="text" id="ordenId" class="form-control bg-light border-start-0" placeholder="Ej: 10245" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">Documento de Identidad</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-id-card text-muted"></i></span>
                        <input type="text" id="cedula" class="form-control bg-light border-start-0" placeholder="Ingrese su Cédula" required>
                    </div>
                </div>

                <div id="error-msg" class="alert alert-danger d-none small p-2 text-center" role="alert"></div>

                <button type="submit" class="btn btn-search w-100 mb-3">
                    <i class="fas fa-download me-2"></i> BUSCAR Y DESCARGAR PDF
                </button>
            </form>

            <div class="text-center mt-3 border-top pt-3">
                <a href="/login" class="text-decoration-none small text-muted">
                    <i class="fas fa-arrow-left me-1"></i> Volver al inicio
                </a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('consultaForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const ordenId = document.getElementById('ordenId').value;
            const cedula = document.getElementById('cedula').value;
            const errorDiv = document.getElementById('error-msg');
            const btn = e.target.querySelector('button');

            try {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Buscando...';
                errorDiv.classList.add('d-none');

                // Endpoint público que valida orden + cédula
                const response = await fetch('/api/pacientes/verificar-resultado', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ordenId, cedula })
                });

                const data = await response.json();

                if (response.ok) {
                    // Si los datos coinciden, redirigimos directamente a la descarga del PDF
                    window.location.href = `/reportes/descargar/${ordenId}?token_publico=${data.tempToken}`;
                } else {
                    errorDiv.innerText = data.error || "No se encontró la orden o los datos no coinciden.";
                    errorDiv.classList.remove('d-none');
                }
            } catch (error) {
                errorDiv.innerText = "Error de conexión con el laboratorio.";
                errorDiv.classList.remove('d-none');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-download me-2"></i> BUSCAR Y DESCARGAR PDF';
            }
        });
    </script>
</body>
</html>