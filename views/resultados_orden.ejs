<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carga de Resultados - Laboratorio</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .fuera-rango { border: 2px solid #ff4d4d !important; background-color: #fff2f2; }
        .rango-normal { color: #666; font-size: 0.85em; }
        .unidad { font-weight: bold; color: #333; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Resultados: Orden #<%= ordenId %></h2>
        
        <table class="table">
            <thead>
                <tr>
                    <th>Examen</th>
                    <th>Referencia (Mín - Máx)</th>
                    <th>Valor Obtenido</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <% resultados.forEach(res => { %>
                    <tr>
                        <td><%= res.examen_nombre %></td>
                        <td class="rango-normal">
                            <%= res.minimo %> - <%= res.maximo %> <span class="unidad"><%= res.unidad %></span>
                        </td>
                        <td>
                            <input type="number" step="0.01" 
                                   id="input-<%= res.id %>" 
                                   value="<%= res.valor_obtenido %>"
                                   class="form-control <%= res.fuera_de_rango ? 'fuera-rango' : '' %>">
                        </td>
                        <td>
                            <button class="btn-save" onclick="enviarResultado(<%= res.id %>)">Guardar</button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
        <br>
        <a href="/ordenes" class="btn-link">Volver a Órdenes</a>
    </div>

    <script>
        async function enviarResultado(id) {
            const valor = document.getElementById(`input-${id}`).value;
            const token = localStorage.getItem('token');

            try {
                const response = await fetch('/resultados/guardar', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ resultado_id: id, valor_obtenido: valor })
                });

                const data = await response.json();
                
                if (response.ok) {
                    if (data.fueraDeRango) {
                        document.getElementById(`input-${id}`).classList.add('fuera-rango');
                        alert("⚠️ ¡Atención! El valor está fuera de rango.");
                    } else {
                        document.getElementById(`input-${id}`).classList.remove('fuera-rango');
                        alert("✅ Resultado guardado correctamente.");
                    }
                }
            } catch (error) {
                alert("Error de conexión al guardar.");
            }
        }
    </script>
</body>
</html>