<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carga de Resultados - Laboratorio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; padding-top: 50px; }
        .container { background: white; padding: 30px; border-radius: 10px; box-shadow: 0 0 15px rgba(0,0,0,0.1); }
        .fuera-rango { border: 2px solid #dc3545 !important; background-color: #f8d7da !important; color: #842029; }
        .rango-normal { color: #6c757d; font-size: 0.9em; }
        .unidad { font-weight: bold; color: #212529; }
    </style>
</head>
<body>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Resultados: Orden #<%= ordenId %></h2>
            <a href="/reportes/descargar/<%= ordenId %>" class="btn btn-danger">
                Descargar Reporte PDF
            </a>
        </div>
        
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Examen</th>
                    <th>Referencia (Mín - Máx)</th>
                    <th>Valor Obtenido</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <% resultados.forEach(res => { %>
                    <tr>
                        <td class="align-middle"><%= res.examen_nombre %></td>
                        <td class="align-middle rango-normal">
                            <%= res.minimo %> - <%= res.maximo %> <span class="unidad"><%= res.unidad %></span>
                        </td>
                        <td>
                            <input type="number" step="0.01" 
                                   id="input-<%= res.id %>" 
                                   value="<%= res.valor_obtenido %>"
                                   class="form-control <%= res.fuera_de_rango ? 'fuera-rango' : '' %>"
                                   placeholder="Ingresar valor">
                        </td>
                        <td class="align-middle">
                            <button class="btn btn-primary w-100" onclick="enviarResultado(<%= res.id %>)">
                                Guardar
                            </button>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
        
        <div class="mt-4">
            <a href="/ordenes" class="btn btn-outline-secondary">Volver a Órdenes</a>
        </div>
    </div>

    <script>
        async function enviarResultado(id) {
            const inputElement = document.getElementById(`input-${id}`);
            const valor = inputElement.value;

            try {
                const response = await fetch('/resultados/guardar', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ resultado_id: id, valor_obtenido: valor })
                });

                const data = await response.json();
                
                if (response.ok) {
                    if (data.fueraDeRango) {
                        inputElement.classList.add('fuera-rango');
                        alert("⚠️ VALOR FUERA DE RANGO: Se ha marcado en el sistema.");
                    } else {
                        inputElement.classList.remove('fuera-rango');
                        alert("✅ Resultado guardado correctamente.");
                    }
                } else {
                    alert("❌ Error: " + (data.error || "No se pudo guardar"));
                }
            } catch (error) {
                console.error(error);
                alert("Error de conexión con el servidor.");
            }
        }
    </script>
</body>
</html>