<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Exámenes - Laboratorio</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <nav>
        <a href="/pacientes">Pacientes</a> | 
        <a href="/examenes"><strong>Exámenes</strong></a> |
        <a href="/facturas">Facturación</a> |
        <a href="/medicos">Médicos</a> |
        <a href="/inventario">Inventario</a> |
        <a href="/valores">Valores Ref.</a>
        <button onclick="logout()" style="float: right; background: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Cerrar Sesión</button>
    </nav>

    <h1>Historial de Exámenes</h1>
    <section>
        <form id="examen-form">
            <select id="paciente_id" required>
                <option value="">Seleccione Paciente</option>
            </select>
            <input type="text" id="tipo_examen" placeholder="Tipo de Examen" required>
            <input type="text" id="resultado" placeholder="Resultado" required>
            <input type="date" id="fecha" required>
            <button type="submit">Registrar</button>
        </form>
    </section>
    <hr>
    <table id="examenes-table" border="1">
        <thead>
            <tr><th>Paciente</th><th>Examen</th><th>Resultado</th><th>Fecha</th></tr>
        </thead>
        <tbody></tbody>
    </table>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login';

        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('rol');
            window.location.href = '/login';
        }

        async function cargarDatos() {
            try {
                const headers = { 'Authorization': `Bearer ${token}` };
                
                const resPacientes = await fetch('/api/pacientes', { headers });
                const pacientes = await resPacientes.json();
                const select = document.getElementById('paciente_id');
                pacientes.forEach(p => {
                    select.innerHTML += `<option value="${p.id}">${p.nombre}</option>`;
                });

                const resExamenes = await fetch('/api/examenes', { headers });
                const examenes = await resExamenes.json();
                const tbody = document.querySelector('#examenes-table tbody');
                tbody.innerHTML = '';
                examenes.forEach(e => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${e.paciente_nombre || 'N/A'}</td>
                            <td>${e.tipo_examen}</td>
                            <td>${e.resultado}</td>
                            <td>${new Date(e.fecha).toLocaleDateString()}</td>
                        </tr>`;
                });
            } catch (err) { console.error("Error cargando datos:", err); }
        }

        document.getElementById('examen-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const datos = {
                paciente_id: document.getElementById('paciente_id').value,
                tipo_examen: document.getElementById('tipo_examen').value,
                resultado: document.getElementById('resultado').value,
                fecha: document.getElementById('fecha').value
            };

            const response = await fetch('/api/examenes', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });

            if (response.ok) location.reload();
            else alert("Error al registrar examen");
        });

        cargarDatos();
    </script>
</body>
</html>